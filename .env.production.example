# --- PRODUCTION .env ---------------------------------------------------------
# Copy this to your VPS as .env and fill in the values.
# DO NOT commit secrets to Git.

# --- DATABASE ----------------------------------------------------------------
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST/neondb?sslmode=require&channel_binding=require"

# --- NEXTAUTH -----------------------------------------------------------------
# Generate new secret: openssl rand -hex 32
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"
NEXTAUTH_URL="https://www.khabar24times.in"

# --- SITE URL -----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://www.khabar24times.in"

# --- CLOUDINARY ---------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="dq6c8h2g0"
CLOUDINARY_API_KEY="456417927464192"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET"

# --- GOOGLE OAUTH -------------------------------------------------------------
# Add https://www.khabar24times.in/api/auth/callback/google to Google Console!
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

NODE_ENV="production"
